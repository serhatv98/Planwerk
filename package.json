// ── RENDER ───────────────────────────────────────
function render() {
  renderSidebar('sidebarList');
  renderSidebar('drawerList');
  if (activeProjId) {
    document.getElementById('noProj').style.display = 'none';
    document.getElementById('projView').style.display = 'block';
    renderProject();
  } else {
    document.getElementById('noProj').style.display = 'block';
    document.getElementById('noProjTitle').textContent = T('keineProj');
    document.getElementById('projView').style.display = 'none';
  }
}

function renderSidebar(listId) {
  var el = document.getElementById(listId);
  el.innerHTML = '';
  var colors = ['#00897b','#1565c0','#6a1b9a','#c0392b','#e65c00'];
  projects.forEach(function(p, i) {
    var total = p.aufgaben.length;
    var done = p.aufgaben.filter(function(a){ return aktV(a).status === 'Abgeschlossen'; }).length;
    var div = document.createElement('div');
    div.className = 'proj-item' + (p.id === activeProjId ? ' active' : '');
    div.innerHTML = '<div class="proj-dot" style="background:'+colors[i%colors.length]+'"></div><div class="proj-name">'+p.name+'</div><div class="proj-count">'+done+'/'+total+'</div>';
    div.addEventListener('click', function(){ activeProjId = p.id; activeFilter = 'all'; closeDrawer(); render(); });
    el.appendChild(div);
  });
}

function renderProject() {
  var p = getActive();
  if (!p) return;
  var totalSoll = p.aufgaben.reduce(function(s,a){ return s + (aktV(a).soll||0); }, 0);
  var totalIst = p.aufgaben.reduce(function(s,a){ return s + (aktV(a).ist||0); }, 0);
  var done = p.aufgaben.filter(function(a){ return aktV(a).status === 'Abgeschlossen'; }).length;
  var inb = p.aufgaben.filter(function(a){ return aktV(a).status === 'In Bearbeitung'; }).length;
  var pct = totalSoll > 0 ? Math.round(totalIst/totalSoll*100) : 0;

  var html = '<div class="proj-header">'
    + '<div><div class="proj-title">'+p.name+' <span style="font-size:14px;color:var(--muted);font-weight:400">— '+p.desc+'</span></div>'
    + '<div class="proj-meta">'+T('verantwLabel')+': '+p.owner+' · '+T('endterminLabel')+': '+p.deadline+'</div></div>'
    + '<button class="btn-primary" id="addAufgBtn">'+T('addAufg')+'</button></div>'
    + '<div class="stats-bar">'
    + '<div class="stat-card"><div class="stat-label">'+T('gesamt')+'</div><div class="stat-value">'+p.aufgaben.length+'</div><div class="stat-sub">'+done+' '+T('abgeschl')+'</div></div>'
    + '<div class="stat-card"><div class="stat-label">'+T('inBearb')+'</div><div class="stat-value" style="color:var(--teal)">'+inb+'</div><div class="stat-sub">'+T('aktivAufg')+'</div></div>'
    + '<div class="stat-card"><div class="stat-label">'+T('sollGes')+'</div><div class="stat-value">'+totalSoll+'h</div><div class="stat-sub">'+T('geplant')+'</div></div>'
    + '<div class="stat-card"><div class="stat-label">'+T('istGes')+'</div><div class="stat-value" style="color:'+(totalIst>totalSoll?'var(--coral)':'var(--navy)')+'">'+totalIst+'h</div><div class="stat-sub">'+pct+'% '+T('verbraucht')+'</div></div>'
    + '</div>'
    + '<div class="filter-bar">'
    + ['all','Offen','In Bearbeitung','In Prüfung','Freigegeben','Abgeschlossen'].map(function(f){
        var label = f === 'all' ? T('alle') : f;
        return '<button class="filter-btn'+(activeFilter===f?' active':'')+'" data-filter="'+f+'">'+label+'</button>';
      }).join('')
    + '</div>'
    + '<div id="cardList">'
    + p.aufgaben.map(function(a){ return renderCard(a); }).join('')
    + '</div>';

  document.getElementById('projView').innerHTML = html;

  document.getElementById('addAufgBtn').addEventListener('click', function(){ openAufgModal(null); });

  document.querySelectorAll('.filter-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      activeFilter = btn.dataset.filter;
      render();
    });
  });

  document.querySelectorAll('.card-header').forEach(function(h){
    h.addEventListener('click', function(){ toggleCard(h.dataset.id); });
  });

  document.querySelectorAll('.st-sel').forEach(function(sel){
    sel.addEventListener('change', function(){ quickStatus(sel.dataset.id, sel.value); });
  });

  document.querySelectorAll('.btn-edit').forEach(function(btn){
    btn.addEventListener('click', function(e){ e.stopPropagation(); openAufgModal(btn.dataset.id); });
  });

  // Aktif revizyonu sil
  document.querySelectorAll('.btn-del-aktiv').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      var p = getActive();
      var a = p.aufgaben.find(function(x){ return x.id === btn.dataset.id; });
      if (!a || a.versionen.length <= 1) { alert(T('nurAktiv')); return; }
      if (!confirm(T('revLoeschFrage'))) return;
      a.versionen.pop();
      save(); render();
    });
  });

  // Arşiv revizyonunu sil (sadece admin)
  document.querySelectorAll('.btn-del-rev').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      if (currentUser !== 'admin') return;
      if (!confirm(T('revLoeschFrage'))) return;
      var p = getActive();
      var a = p.aufgaben.find(function(x){ return x.id === btn.dataset.aid; });
      if (!a) return;
      var ver = parseInt(btn.dataset.ver);
      a.versionen = a.versionen.filter(function(vv){ return vv.ver !== ver; });
      // Versiyon numaralarını düzelt
      a.versionen.forEach(function(vv, i){ vv.ver = i+1; });
      save(); render();
    });
  });

  // Tüm görevi sil (sadece admin)
  document.querySelectorAll('.btn-del-all').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      if (currentUser !== 'admin') return;
      if (!confirm(T('aufgLoeschFrage'))) return;
      var p = getActive();
      p.aufgaben = p.aufgaben.filter(function(a){ return a.id !== btn.dataset.id; });
      save(); render();
    });
  });

  // Arşiv revizyonu tıklanınca detay aç/kapat
  document.querySelectorAll('[data-rev-view]').forEach(function(row){
    row.addEventListener('click', function(e){
      if (e.target.classList.contains('btn-del-rev')) return;
      var key = row.dataset.revView;
      var detail = document.getElementById('revd-'+key);
      if (detail) detail.style.display = detail.style.display === 'none' ? 'block' : 'none';
    });
  });

  document.querySelectorAll('.btn-rev').forEach(function(btn){
    btn.addEventListener('click', function(e){ e.stopPropagation(); openRevModal(btn.dataset.id); });
  });

  applyFilter();
}

function renderCard(a) {
  var v = aktV(a);
  var vers = a.versionen;
  var verNum = vers.length;
  var sc = statusClass(v.status);
  var pct = v.soll > 0 ? Math.min(Math.round((v.ist||0)/v.soll*100),100) : 0;
  var over = (v.ist||0) > (v.soll||0);

  var inputsHtml = (v.inputs||[]).length === 0
    ? '<div class="io-empty">'+T('keineInputs')+'</div>'
    : v.inputs.map(function(i){ return '<div class="io-item"><div class="io-name">📄 '+i.name+'</div><div class="io-meta">'+T('von')+': '+i.von+' · '+i.abt+' · '+(i.datum||'—')+'</div></div>'; }).join('');

  var outputsHtml = (v.outputs||[]).length === 0
    ? '<div class="io-empty">'+T('keineOutputs')+'</div>'
    : v.outputs.map(function(o){ return '<div class="io-item"><div class="io-name">📤 '+o.name+'</div><div class="io-meta">'+T('an')+': '+(o.ziel||'—')+' · '+(o.datum||'—')+'</div></div>'; }).join('');

  var archiv = vers.slice(0, -1);
  var revHistHtml = '<div class="rev-hist"><div class="rev-hist-title">📋 '+T('versHist')+'</div>'
    + archiv.map(function(vv){
        var canDelRev = currentUser === 'admin';
        return '<div class="rev-row" style="cursor:pointer" data-rev-view="'+a.id+'-'+vv.ver+'">'
          + '<span class="rev-ver arc">v'+vv.ver+'</span>'
          + '<span><span class="pill '+statusClass(vv.status)+'" style="font-size:10px">'+vv.status+'</span></span>'
          + '<span style="color:var(--muted);font-family:\'DM Mono\',monospace;font-size:11px">'+(vv.termin||'—')+'</span>'
          + (vv.grund?'<span class="rev-grund">↳ '+vv.grund+'</span>':'')
          + (canDelRev?'<button class="btn-sm btn-del-rev" style="padding:3px 8px;font-size:10px;margin-left:auto" data-aid="'+a.id+'" data-ver="'+vv.ver+'">×</button>':'')
          + '</div>'
          + '<div class="rev-detail" id="revd-'+a.id+'-'+vv.ver+'" style="display:none;background:var(--ice2);border-radius:6px;padding:10px;margin:4px 0 8px;font-size:12px">'
          + '<b>Inputs:</b> '+(vv.inputs&&vv.inputs.length?vv.inputs.map(function(i){return i.name+' ('+i.von+')'}).join(', '):'—')+'<br>'
          + '<b>Outputs:</b> '+(vv.outputs&&vv.outputs.length?vv.outputs.map(function(o){return o.name+' → '+(o.ziel||'—')}).join(', '):'—')+'<br>'
          + '<b>Soll/Ist:</b> '+(vv.soll||0)+'h / '+(vv.ist||0)+'h'
          + (vv.notes?'<br><i>'+vv.notes+'</i>':'')
          + '</div>';
      }).join('')
    + '<div class="rev-row"><span class="rev-ver" style="color:var(--teal)">v'+verNum+'</span>'
    + '<span><span class="pill '+sc+'" style="font-size:10px">'+v.status+'</span></span>'
    + '<span style="color:var(--muted);font-family:\'DM Mono\',monospace;font-size:11px">'+(v.termin||'—')+'</span>'
    + '<span style="font-size:10px;color:var(--teal);font-family:\'DM Mono\',monospace">'+T('aktiv')+'</span></div>'
    + '</div>';

  var visible = (activeFilter === 'all' || v.status === activeFilter);

  return '<div class="card" data-st="'+v.status+'" data-aid="'+a.id+'" style="'+(visible?'':'display:none')+'">'
    + '<div class="card-header" data-id="'+a.id+'">'
    + '<span class="pill '+sc+'">'+v.status+'</span>'
    + '<div class="card-name">'+a.name+(verNum>1?'<span class="rev-badge">v'+verNum+'</span>':'')+'</div>'
    + '<div class="card-meta"><span class="chip">👤 '+a.owner+'</span><span class="chip">⏱ '+(v.ist||0)+'/'+(v.soll||0)+'h</span><span class="chip">📅 '+(v.termin||'—')+'</span></div>'
    + '<span class="chevron">▾</span></div>'
    + '<div class="card-body">'
    + '<div class="detail-grid">'
    + '<div class="dsec"><div class="dsec-title">'+T('eingangsd')+'</div>'+inputsHtml+'</div>'
    + '<div class="dsec"><div class="dsec-title">'+T('ausgangsd')+'</div>'+outputsHtml+'</div>'
    + '<div class="dsec"><div class="dsec-title">'+T('stundenInfo')+'</div>'
    + '<div class="hr"><span class="hr-label">'+T('soll')+'</span><span class="hr-val">'+(v.soll||0)+'h</span></div>'
    + '<div class="hr"><span class="hr-label">'+T('ist')+'</span><span class="hr-val'+(over?' over':'')+'"><b>'+(v.ist||0)+'h</b></span></div>'
    + '<div class="pbar"><div class="pfill'+(over?' over':'')+'" style="width:'+pct+'%"></div></div>'
    + (a.dept?'<div class="hr" style="margin-top:8px"><span class="hr-label">'+T('dept')+'</span><span class="hr-val" style="font-size:11px;font-weight:400">'+a.dept+'</span></div>':'')
    + (a.abh?'<div class="hr"><span class="hr-label">'+T('benoetigt')+'</span><span class="hr-val" style="font-size:11px;font-weight:400;color:var(--amber)">⚠ '+a.abh+'</span></div>':'')
    + (v.notes?'<div style="margin-top:8px;font-size:12px;color:var(--muted);font-style:italic">'+v.notes+'</div>':'')
    + '</div></div>'
    + revHistHtml
    + '<div class="actions">'
    + '<select class="st-sel" data-id="'+a.id+'">'
    + ['Offen','In Bearbeitung','In Prüfung','Freigegeben','Abgeschlossen'].map(function(s){ return '<option value="'+s+'"'+(s===v.status?' selected':'')+'>'+s+'</option>'; }).join('')
    + '</select>'
    + '<button class="btn-sm btn-edit" data-id="'+a.id+'">'+T('bearbeiten')+'</button>'
    + '<button class="btn-rev" data-id="'+a.id+'">'+T('revision')+'</button>'
    + (verNum > 1 ? '<button class="btn-sm btn-del-aktiv" data-id="'+a.id+'" style="border-color:#ffcdd2;background:#fff5f5;color:var(--coral)">🗑 Rev. v'+verNum+' löschen</button>' : '')
    + (currentUser === 'admin' ? '<button class="btn-sm btn-del-all" data-id="'+a.id+'" style="border-color:#b71c1c;background:#ffebee;color:#b71c1c">🗑 Aufgabe löschen</button>' : '')
    + '</div></div></div>';
}

function toggleCard(id) {
  var card = document.querySelector('.card[data-aid="'+id+'"]');
  if (card) card.classList.toggle('open');
}

function applyFilter() {
  document.querySelectorAll('.card').forEach(function(c){
    var st = c.dataset.st;
    c.style.display = (activeFilter === 'all' || st === activeFilter) ? 'block' : 'none';
  });
}

function doSearch(val) {
  var q = val.toLowerCase();
  document.querySelectorAll('.card').forEach(function(c){
    var name = c.querySelector('.card-name') ? c.querySelector('.card-name').textContent.toLowerCase() : '';
    c.style.display = name.includes(q) ? 'block' : 'none';
  });
}

function quickStatus(id, status) {
  var p = getActive();
  var a = p.aufgaben.find(function(x){ return x.id === id; });
  if (!a) return;
  aktV(a).status = status;
  save();
  render();
}

function doDelete(id) {
  if (!confirm(T('loeschenFrage'))) return;
  var p = getActive();
  p.aufgaben = p.aufgaben.filter(function(a){ return a.id !== id; });
  save();
  render();
}

function toggleAdmin() {
  if (currentUser === 'admin') {
    currentUser = null;
    document.getElementById('adminBtn').textContent = '🔐 Admin';
    document.getElementById('adminBtn').style.background = 'rgba(255,255,255,0.1)';
    render();
  } else {
    document.getElementById('fAdminPw').value = '';
    document.getElementById('adminErr').style.display = 'none';
    document.getElementById('modalAdmin').classList.add('open');
    setTimeout(function(){ document.getElementById('fAdminPw').focus(); }, 100);
  }
}

function doAdminLogin() {
  var pw = document.getElementById('fAdminPw').value;
  if (pw === ADMIN_PW) {
    currentUser = 'admin';
    document.getElementById('adminBtn').textContent = '✓ Admin';
    document.getElementById('adminBtn').style.background = 'var(--teal)';
    closeModal('modalAdmin');
    render();
  } else {
    document.getElementById('adminErr').style.display = 'block';
  }
}

document.getElementById('fAdminPw').addEventListener('keydown', function(e){
  if (e.key === 'Enter') doAdminLogin();
});

// ── PROJE MODAL ──────────────────────────────────
function openProjModal() {
  document.getElementById('fProjName').value = '';
  document.getElementById('fProjDesc').value = '';
  document.getElementById('fProjOwner').value = '';
  document.getElementById('fProjDeadline').value = '';
  document.getElementById('modalProj').classList.add('open');
}

document.getElementById('saveProj').addEventListener('click', function(){
  var name = document.getElementById('fProjName').value.trim();
  if (!name) return;
  var colors = ['#00897b','#1565c0','#6a1b9a','#c0392b','#e65c00'];
  var p = { id: 'p'+Date.now(), name: name, desc: document.getElementById('fProjDesc').value.trim(),
    owner: document.getElementById('fProjOwner').value.trim(), deadline: document.getElementById('fProjDeadline').value,
    color: colors[projects.length % colors.length], aufgaben: [] };
  projects.push(p);
  activeProjId = p.id;
  save();
  closeModal('modalProj');
  render();
});

document.getElementById('cancelProj').addEventListener('click', function(){ closeModal('modalProj'); });

// ── AUFGABE MODAL ────────────────────────────────
function openAufgModal(id) {
  editAufgId = id;
  var p = getActive();
  var a = id ? p.aufgaben.find(function(x){ return x.id === id; }) : null;
  var v = a ? aktV(a) : null;
  document.getElementById('modalAufgTitle').textContent = a ? T('bearbAufg') : T('neueAufg');
  document.getElementById('fAName').value = a ? a.name : '';
  document.getElementById('fAOwner').value = a ? a.owner : '';
  document.getElementById('fADept').value = a ? a.dept : '';
  document.getElementById('fASoll').value = v ? (v.soll||'') : '';
  document.getElementById('fAIst').value = v ? (v.ist||'') : '';
  document.getElementById('fATermin').value = v ? (v.termin||'') : '';
  document.getElementById('fAStatus').value = v ? v.status : 'Offen';
  document.getElementById('fAAbh').value = a ? a.abh : '';
  document.getElementById('fANotes').value = v ? (v.notes||'') : '';
  renderIOList('inputList', 'input', v ? (v.inputs||[]) : []);
  renderIOList('outputList', 'output', v ? (v.outputs||[]) : []);
  document.getElementById('modalAufg').classList.add('open');
}

document.getElementById('saveAufg').addEventListener('click', function(){
  var p = getActive();
  var name = document.getElementById('fAName').value.trim();
  if (!name) return;
  var inputs = getIOList('inputList', 'input');
  var outputs = getIOList('outputList', 'output');
  var soll = parseFloat(document.getElementById('fASoll').value) || 0;
  var ist = parseFloat(document.getElementById('fAIst').value) || 0;
  var termin = document.getElementById('fATermin').value;
  var status = document.getElementById('fAStatus').value;
  var notes = document.getElementById('fANotes').value.trim();
  if (editAufgId) {
    var a = p.aufgaben.find(function(x){ return x.id === editAufgId; });
    if (a) {
      a.name = name; a.owner = document.getElementById('fAOwner').value.trim();
      a.dept = document.getElementById('fADept').value.trim(); a.abh = document.getElementById('fAAbh').value.trim();
      var v = aktV(a);
      v.soll = soll; v.ist = ist; v.termin = termin; v.status = status; v.notes = notes;
      v.inputs = inputs; v.outputs = outputs;
    }
  } else {
    p.aufgaben.push({ id: 'a'+Date.now(), name: name,
      owner: document.getElementById('fAOwner').value.trim(),
      dept: document.getElementById('fADept').value.trim(),
      abh: document.getElementById('fAAbh').value.trim(),
      versionen: [{ ver:1, status:status, soll:soll, ist:ist, termin:termin, notes:notes, grund:'', inputs:inputs, outputs:outputs }]
    });
  }
  save(); closeModal('modalAufg'); render();
});

document.getElementById('cancelAufg').addEventListener('click', function(){ closeModal('modalAufg'); });

// ── IO LIST ──────────────────────────────────────
function renderIOList(containerId, type, entries) {
  var c = document.getElementById(containerId);
  c.innerHTML = '';
  entries.forEach(function(e){ addIORow(containerId, type, e); });
}

function addIORow(containerId, type, data) {
  var c = document.getElementById(containerId);
  var div = document.createElement('div');
  div.className = 'io-entry';
  var v1 = data ? (data.name||'') : '';
  var v2 = data ? (type==='input' ? (data.von||'') : (data.ziel||'')) : '';
  var v3 = data ? ((data.abt||'') + (data.datum ? ' · '+data.datum : '')) : '';
  div.innerHTML = '<div class="fg" style="margin:0"><label class="fl">'+T('dateiname')+'</label><input class="fi" placeholder="Datei.pdf" value="'+v1+'"></div>'
    + '<div class="fg" style="margin:0"><label class="fl">'+(type==='input'?T('von'):T('an'))+'</label><input class="fi" placeholder="Name" value="'+v2+'"></div>'
    + '<div class="fg" style="margin:0"><label class="fl">'+T('abtDatum')+'</label><input class="fi" placeholder="Abt. · TT.MM." value="'+v3+'"></div>'
    + '<button class="io-rm" type="button">×</button>';
  div.querySelector('.io-rm').addEventListener('click', function(){ div.remove(); });
  c.appendChild(div);
}

function getIOList(containerId, type) {
  var c = document.getElementById(containerId);
  var result = [];
  c.querySelectorAll('.io-entry').forEach(function(div){
    var ins = div.querySelectorAll('input');
    var name = ins[0].value.trim();
    if (!name) return;
    var raw = ins[2].value.split('·');
    if (type === 'input') result.push({ name:name, von:ins[1].value.trim(), abt:(raw[0]||'').trim(), datum:(raw[1]||'').trim() });
    else result.push({ name:name, ziel:ins[1].value.trim(), abt:(raw[0]||'').trim(), datum:(raw[1]||'').trim() });
  });
  return result;
}

document.getElementById('addInputBtn').addEventListener('click', function(){ addIORow('inputList','input',null); });
document.getElementById('addOutputBtn').addEventListener('click', function(){ addIORow('outputList','output',null); });

// ── REVISION MODAL ───────────────────────────────
function openRevModal(id) {
  revTargetId = id;
  document.getElementById('fRevGrund').value = '';
  document.getElementById('fRevTermin').value = '';
  document.getElementById('fRevSoll').value = '';
  document.getElementById('modalRev').classList.add('open');
}

document.getElementById('saveRev').addEventListener('click', function(){
  var p = getActive();
  var a = p.aufgaben.find(function(x){ return x.id === revTargetId; });
  if (!a) return;
  var current = aktV(a);
  var newVer = {
    ver: a.versionen.length + 1,
    status: 'In Bearbeitung',
    soll: parseFloat(document.getElementById('fRevSoll').value) || current.soll,
    ist: 0,
    termin: document.getElementById('fRevTermin').value || current.termin,
    notes: '',
    grund: document.getElementById('fRevGrund').value.trim(),
    inputs: [], outputs: []
  };
  a.versionen.push(newVer);
  save(); closeModal('modalRev'); render();
  setTimeout(function(){
    var card = document.querySelector('.card[data-aid="'+revTargetId+'"]');
    if (card) card.classList.add('open');
  }, 100);
});

document.getElementById('cancelRev').addEventListener('click', function(){ closeModal('modalRev'); });

// ── MODAL ────────────────────────────────────────
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.overlay').forEach(function(ov){
  ov.addEventListener('click', function(e){ if (e.target === ov) ov.classList.remove('open'); });
});

// ── DRAWER ───────────────────────────────────────
function openDrawer() {
  document.getElementById('drawer').classList.add('open');
  document.getElementById('drawerOverlay').classList.add('open');
}
function closeDrawer() {
  document.getElementById('drawer').classList.remove('open');
  document.getElementById('drawerOverlay').classList.remove('open');
}
document.getElementById('hamburgerBtn').addEventListener('click', openDrawer);
document.getElementById('drawerClose').addEventListener('click', closeDrawer);
document.getElementById('drawerOverlay').addEventListener('click', closeDrawer);
document.getElementById('sidebarAddBtn').addEventListener('click', openProjModal);
document.getElementById('drawerAddBtn').addEventListener('click', function(){ openProjModal(); closeDrawer(); });

// ── INIT ─────────────────────────────────────────
load();
if (projects.length > 0 && !activeProjId) activeProjId = projects[0].id;
render();
</script>
</body>
</html>
