  if (projects.length === 0) {
    projects = [{
      id: 'p1', name: 'KES-2024-07', desc: 'Kesselgewichtsberechnung',
      owner: 'K. Yılmaz', deadline: '2026-06-10', color: '#00897b',
      aufgaben: [
        { id: 'a1', name: 'Druckberechnung bereitstellen', owner: 'M. Weber', dept: 'Konstruktion', abh: '',
          versionen: [{ ver:1, status:'Abgeschlossen', soll:8, ist:6, termin:'2026-06-02', notes:'Sammler-Abmessungen notwendig.', grund:'', inputs:[], outputs:[{name:'Druckberechnung_v1.pdf', von:'M. Weber', abt:'Konstruktion', datum:'2026-06-02', ziel:'K. Yılmaz'}] }] },
        { id: 'a2', name: 'Wandstärke Sammler bestimmen', owner: 'K. Yılmaz', dept: 'Statik & Festigkeit', abh: 'Druckberechnung abgeschlossen',
          versionen: [{ ver:1, status:'In Bearbeitung', soll:4, ist:4, termin:'2026-06-04', notes:'', grund:'', inputs:[{name:'Druckberechnung_v1.pdf', von:'M. Weber', abt:'Konstruktion', datum:'2026-06-02'}], outputs:[] }] },
        { id: 'a3', name: 'Statikberechnung (Grundgeometrie)', owner: 'K. Yılmaz', dept: 'Statik & Festigkeit', abh: 'Geometrie vom Auftraggeber',
          versionen: [{ ver:1, status:'Offen', soll:12, ist:0, termin:'2026-06-06', notes:'', grund:'', inputs:[], outputs:[{name:'Statikbericht_KES2024.pdf', von:'K. Yılmaz', abt:'Statik', datum:'', ziel:'Konstruktion'}] }] },
        { id: 'a4', name: 'Prüfung Wandstärke', owner: 'T. Müller', dept: 'Prüfung', abh: 'Wandstärke abgeschlossen',
          versionen: [{ ver:1, status:'Offen', soll:2, ist:0, termin:'2026-06-05', notes:'', grund:'', inputs:[], outputs:[] }] },
        { id: 'a5', name: 'Freigabe durch Projektleiter', owner: 'Hr. Schmidt', dept: 'Projektleitung', abh: 'Beide Prüfungen abgeschlossen',
