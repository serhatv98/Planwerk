function save() { localStorage.setItem('pt2', JSON.stringify(projects)); }
function getProj(id) { return projects.find(function(p){ return p.id === id; }); }
function getActive() { return getProj(activeProjId); }
function aktV(a) { return a.versionen[a.versionen.length - 1]; }

function statusClass(st) {
  return { 'Offen':'st-offen', 'In Bearbeitung':'st-inb', 'In Prüfung':'st-prue', 'Freigegeben':'st-frei', 'Abgeschlossen':'st-abg' }[st] || 'st-offen';
}

// ── LANG ─────────────────────────────────────────
