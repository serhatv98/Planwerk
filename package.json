<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Projekttracker</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #1a2342; --navy2: #232f52; --teal: #00897b; --teal2: #00bfa5;
  --amber: #e6a817; --coral: #c0392b; --green: #2e7d52;
  --ice: #e8edf8; --ice2: #f4f7ff; --muted: #8a94b0;
  --border: #dde3f0; --text: #1a2342; --white: #ffffff;
  --radius: 10px; --shadow: 0 2px 16px rgba(26,35,66,0.10);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: var(--ice2); color: var(--text); min-height: 100vh; }

.topbar {
  background: var(--navy); color: var(--white);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 20px; height: 54px; position: sticky; top: 0; z-index: 100;
  box-shadow: 0 2px 12px rgba(0,0,0,0.18);
}
.topbar-title { font-size: 15px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
.topbar-title span { color: var(--teal2); }
.topbar-right { display: flex; align-items: center; gap: 8px; }
.lang-toggle { display: flex; background: rgba(255,255,255,0.1); border-radius: 20px; overflow: hidden; }
.lang-btn { padding: 5px 14px; border: none; background: transparent; color: rgba(255,255,255,0.6); font-size: 12px; cursor: pointer; font-family: 'DM Mono', monospace; transition: all 0.2s; }
.lang-btn.active { background: var(--teal); color: white; }
.search-box { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); border-radius: 20px; padding: 6px 14px; color: white; font-size: 13px; font-family: 'DM Sans', sans-serif; width: 190px; outline: none; }
.search-box::placeholder { color: rgba(255,255,255,0.4); }
.hamburger { display: none; background: rgba(255,255,255,0.1); border: none; border-radius: 8px; color: white; font-size: 18px; width: 36px; height: 36px; cursor: pointer; }

.layout { display: flex; min-height: calc(100vh - 54px); }

.sidebar { width: 250px; background: var(--navy2); flex-shrink: 0; padding: 16px 0; }
.sidebar-label { font-size: 10px; font-family: 'DM Mono', monospace; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; padding: 0 18px 8px; }
.proj-item { display: flex; align-items: center; gap: 10px; padding: 10px 18px; cursor: pointer; border-left: 3px solid transparent; transition: background 0.15s; }
.proj-item:hover { background: rgba(255,255,255,0.06); }
.proj-item.active { background: rgba(0,137,123,0.18); border-left-color: var(--teal2); }
.proj-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.proj-name { font-size: 13px; font-weight: 500; color: white; flex: 1; }
.proj-count { background: rgba(255,255,255,0.1); border-radius: 10px; padding: 1px 7px; font-size: 10px; font-family: 'DM Mono', monospace; color: var(--muted); }
.add-proj-btn { margin: 12px 14px 0; padding: 9px; border: 1px dashed rgba(255,255,255,0.2); border-radius: var(--radius); background: transparent; color: rgba(255,255,255,0.5); font-size: 12px; cursor: pointer; width: calc(100% - 28px); font-family: 'DM Sans', sans-serif; transition: all 0.2s; }
.add-proj-btn:hover { border-color: var(--teal2); color: var(--teal2); }

.main { flex: 1; padding: 24px; overflow-y: auto; }

.proj-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 20px; }
.proj-title { font-size: 20px; font-weight: 600; }
.proj-meta { font-size: 13px; color: var(--muted); margin-top: 3px; }
.btn-primary { background: var(--teal); color: white; border: none; border-radius: var(--radius); padding: 9px 18px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; white-space: nowrap; }
.btn-primary:hover { background: var(--teal2); }

.stats-bar { display: flex; gap: 12px; margin-bottom: 20px; }
.stat-card { background: white; border-radius: var(--radius); padding: 14px 18px; flex: 1; border: 1px solid var(--border); box-shadow: var(--shadow); }
.stat-label { font-size: 10px; color: var(--muted); font-family: 'DM Mono', monospace; text-transform: uppercase; letter-spacing: 0.5px; }
.stat-value { font-size: 22px; font-weight: 600; color: var(--navy); margin-top: 4px; font-family: 'DM Mono', monospace; }
.stat-sub { font-size: 11px; color: var(--muted); margin-top: 2px; }

.filter-bar { display: flex; gap: 6px; margin-bottom: 16px; flex-wrap: wrap; }
.filter-btn { padding: 6px 12px; border-radius: 20px; border: 1px solid var(--border); background: white; font-size: 12px; cursor: pointer; font-family: 'DM Sans', sans-serif; color: var(--muted); transition: all 0.2s; }
.filter-btn.active, .filter-btn:hover { background: var(--navy); color: white; border-color: var(--navy); }

.card { background: white; border-radius: var(--radius); border: 1px solid var(--border); margin-bottom: 12px; box-shadow: var(--shadow); overflow: hidden; border-left: 4px solid #ccc; }
.card[data-st="Offen"] { border-left-color: #8a94b0; }
.card[data-st="In Bearbeitung"] { border-left-color: var(--teal); }
.card[data-st="In Prüfung"] { border-left-color: var(--amber); }
.card[data-st="Freigegeben"] { border-left-color: var(--green); }
.card[data-st="Abgeschlossen"] { border-left-color: #9c27b0; }

.card-header { display: flex; align-items: center; gap: 12px; padding: 14px 18px; cursor: pointer; user-select: none; }
.pill { padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 500; font-family: 'DM Mono', monospace; white-space: nowrap; flex-shrink: 0; }
.st-offen { background: #e8edf8; color: #4a5580; }
.st-inb { background: #e0f4f1; color: #00695c; }
.st-prue { background: #fff3e0; color: #e65100; }
.st-frei { background: #e8f5e9; color: #2e7d32; }
.st-abg { background: #f3e5f5; color: #6a1b9a; }
.card-name { font-size: 14px; font-weight: 600; flex: 1; }
.card-meta { display: flex; gap: 14px; flex-shrink: 0; }
.chip { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; }
.chevron { font-size: 12px; color: var(--muted); transition: transform 0.2s; margin-left: 4px; }
.card.open .chevron { transform: rotate(180deg); }
.rev-badge { display: inline-flex; align-items: center; background: #fff3e0; color: #e65100; border-radius: 10px; padding: 2px 8px; font-size: 10px; font-family: 'DM Mono', monospace; font-weight: 500; margin-left: 6px; }

.card-body { display: none; border-top: 1px solid var(--border); padding: 18px; background: var(--ice2); }
.card.open .card-body { display: block; }

.detail-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin-bottom: 14px; }
.dsec { background: white; border-radius: 8px; padding: 14px; border: 1px solid var(--border); }
.dsec-title { font-size: 10px; font-family: 'DM Mono', monospace; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 10px; }
.io-item { padding: 7px 0; border-bottom: 1px solid var(--ice); }
.io-item:last-child { border-bottom: none; }
.io-name { font-size: 13px; font-weight: 500; }
.io-meta { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; }
.io-empty { font-size: 12px; color: var(--muted); font-style: italic; }
.hr { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border-bottom: 1px solid var(--ice); }
.hr:last-child { border-bottom: none; }
.hr-label { font-size: 12px; color: var(--muted); }
.hr-val { font-size: 13px; font-weight: 600; font-family: 'DM Mono', monospace; }
.hr-val.over { color: var(--coral); }
.pbar { height: 4px; background: var(--ice); border-radius: 2px; margin-top: 8px; overflow: hidden; }
.pfill { height: 100%; background: var(--teal); border-radius: 2px; }
.pfill.over { background: var(--coral); }

.rev-hist { background: white; border-radius: 8px; padding: 12px 14px; margin-top: 12px; border: 1px solid var(--border); }
.rev-hist-title { font-size: 10px; font-family: 'DM Mono', monospace; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 10px; }
.rev-row { display: flex; align-items: center; gap: 10px; padding: 6px 0; border-bottom: 1px solid var(--ice); font-size: 12px; flex-wrap: wrap; }
.rev-row:last-child { border-bottom: none; }
.rev-ver { font-family: 'DM Mono', monospace; font-weight: 600; color: var(--navy); min-width: 24px; }
.rev-ver.arc { color: var(--muted); }
.rev-grund { color: var(--amber); font-size: 11px; font-style: italic; }

.actions { display: flex; gap: 8px; margin-top: 14px; flex-wrap: wrap; }
.btn-sm { padding: 8px 14px; border-radius: 7px; font-size: 12px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; border: 1px solid var(--border); background: white; color: var(--navy); transition: all 0.15s; }
.btn-sm:hover { background: var(--navy); color: white; border-color: var(--navy); }
.btn-del { border-color: #ffcdd2; background: #fff5f5; color: var(--coral); }
.btn-del:hover { background: var(--coral); color: white; border-color: var(--coral); }
.btn-rev { border: 1px solid var(--amber); background: #fff8e1; color: #b36a00; padding: 8px 14px; border-radius: 7px; font-size: 12px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }
.btn-rev:hover { background: var(--amber); color: white; }
.st-sel { padding: 8px 10px; border-radius: 7px; border: 1px solid var(--border); font-family: 'DM Sans', sans-serif; font-size: 12px; color: var(--navy); background: white; cursor: pointer; }

/* MODAL */
.overlay { display: none; position: fixed; inset: 0; background: rgba(26,35,66,0.55); z-index: 200; align-items: center; justify-content: center; }
.overlay.open { display: flex; }
.modal { background: white; border-radius: 14px; padding: 26px; width: 500px; max-width: 95vw; max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(26,35,66,0.25); }
.modal-title { font-size: 16px; font-weight: 600; color: var(--navy); margin-bottom: 18px; }
.fg { margin-bottom: 12px; }
.fl { font-size: 11px; font-weight: 500; color: var(--muted); margin-bottom: 4px; display: block; font-family: 'DM Mono', monospace; text-transform: uppercase; letter-spacing: 0.5px; }
.fi, .fsel, .fta { width: 100%; padding: 9px 11px; border: 1px solid var(--border); border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 13px; color: var(--navy); background: var(--ice2); outline: none; }
.fi:focus, .fsel:focus, .fta:focus { border-color: var(--teal); background: white; }
.fta { min-height: 70px; resize: vertical; }
.frow { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 18px; }
.btn-cancel { padding: 9px 16px; border: 1px solid var(--border); border-radius: 8px; background: white; color: var(--muted); font-size: 13px; cursor: pointer; font-family: 'DM Sans', sans-serif; }
.btn-save { padding: 9px 20px; border: none; border-radius: 8px; background: var(--teal); color: white; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; }

.io-sec { background: var(--ice2); border-radius: 8px; padding: 12px; margin-bottom: 10px; }
.io-sec-title { font-size: 11px; font-weight: 600; color: var(--navy); margin-bottom: 8px; font-family: 'DM Mono', monospace; text-transform: uppercase; }
.io-entry { display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: 6px; margin-bottom: 6px; align-items: end; }
.io-rm { padding: 9px 8px; border: none; background: transparent; color: var(--muted); cursor: pointer; font-size: 16px; border-radius: 6px; }
.io-rm:hover { color: var(--coral); background: #fff0ee; }
.add-io { font-size: 12px; color: var(--teal); background: none; border: none; cursor: pointer; padding: 3px 0; font-family: 'DM Sans', sans-serif; }

/* DRAWER */
.drawer-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 150; }
.drawer-overlay.open { display: block; }
.drawer { position: fixed; top: 0; left: -270px; width: 250px; height: 100vh; background: var(--navy2); z-index: 160; transition: left 0.25s ease; padding: 50px 0 20px; overflow-y: auto; }
.drawer.open { left: 0; }
.drawer-close { position: absolute; top: 12px; right: 12px; background: rgba(255,255,255,0.1); border: none; border-radius: 6px; color: white; font-size: 16px; width: 30px; height: 30px; cursor: pointer; }

.empty { text-align: center; padding: 60px 20px; color: var(--muted); }
.empty-icon { font-size: 44px; margin-bottom: 14px; }
.empty-title { font-size: 15px; font-weight: 600; color: var(--navy); margin-bottom: 6px; }

@media (max-width: 680px) {
  .sidebar { display: none; }
  .hamburger { display: flex; align-items: center; justify-content: center; }
  .search-box { width: 120px; font-size: 12px; }
  .main { padding: 14px; }
  .detail-grid { grid-template-columns: 1fr; }
  .stats-bar { flex-wrap: wrap; gap: 8px; }
  .stat-card { min-width: calc(50% - 4px); flex: none; padding: 10px 12px; }
  .proj-header { flex-direction: column; gap: 10px; }
  .btn-primary { width: 100%; text-align: center; }
  .card-meta { display: none; }
  .frow { grid-template-columns: 1fr; }
  .io-entry { grid-template-columns: 1fr 1fr; }
  .io-entry > div:nth-child(3) { grid-column: 1 / -1; }
}
</style>
</head>
<body>

<div class="topbar">
  <div style="display:flex;align-items:center;gap:10px">
    <button class="hamburger" id="hamburgerBtn">☰</button>
    <div class="topbar-title">◆ <span>Projekt</span>tracker</div>
  </div>
  <div class="topbar-right">
    <input class="search-box" id="searchBox" placeholder="Suchen…" oninput="doSearch(this.value)">
    <button id="adminBtn" onclick="toggleAdmin()" style="background:rgba(255,255,255,0.1);border:none;border-radius:8px;color:rgba(255,255,255,0.7);font-size:12px;padding:6px 12px;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap">🔐 Admin</button>
    <div class="lang-toggle">
      <button class="lang-btn active" id="btnDE" onclick="setLang('de')">DE</button>
      <button class="lang-btn" id="btnEN" onclick="setLang('en')">EN</button>
    </div>
  </div>
</div>

<div class="drawer-overlay" id="drawerOverlay"></div>
<div class="drawer" id="drawer">
  <button class="drawer-close" id="drawerClose">✕</button>
  <div class="sidebar-label">Projekte</div>
  <div id="drawerList"></div>
  <button class="add-proj-btn" id="drawerAddBtn">+ Projekt hinzufügen</button>
</div>

<div class="layout">
  <div class="sidebar">
    <div class="sidebar-label">Projekte</div>
    <div id="sidebarList"></div>
    <button class="add-proj-btn" id="sidebarAddBtn">+ Projekt hinzufügen</button>
  </div>
  <div class="main">
    <div id="noProj" class="empty" style="display:none">
      <div class="empty-icon">📋</div>
      <div class="empty-title" id="noProjTitle">Kein Projekt ausgewählt</div>
    </div>
    <div id="projView"></div>
  </div>
</div>

<!-- MODAL: PROJEKT -->
<div class="overlay" id="modalProj">
  <div class="modal">
    <div class="modal-title" id="modalProjTitle">Neues Projekt</div>
    <div class="fg"><label class="fl" id="lProjName">Projektname</label><input class="fi" id="fProjName" placeholder="z.B. KES-2024-07"></div>
    <div class="fg"><label class="fl" id="lProjDesc">Beschreibung</label><input class="fi" id="fProjDesc" placeholder="z.B. Kesselgewichtsberechnung"></div>
    <div class="frow">
      <div class="fg"><label class="fl" id="lProjOwner">Verantwortlich</label><input class="fi" id="fProjOwner" placeholder="Name"></div>
      <div class="fg"><label class="fl" id="lProjDeadline">Endtermin</label><input class="fi" type="date" id="fProjDeadline"></div>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" id="cancelProj">Abbrechen</button>
      <button class="btn-save" id="saveProj">Speichern</button>
    </div>
  </div>
</div>

<!-- MODAL: AUFGABE -->
<div class="overlay" id="modalAufg">
  <div class="modal">
    <div class="modal-title" id="modalAufgTitle">Neue Aufgabe</div>
    <div class="fg"><label class="fl" id="lAName">Aufgabenname</label><input class="fi" id="fAName" placeholder="z.B. Statikberechnung"></div>
    <div class="frow">
      <div class="fg"><label class="fl" id="lAOwner">Verantwortlich</label><input class="fi" id="fAOwner" placeholder="Name"></div>
      <div class="fg"><label class="fl" id="lADept">Abteilung</label><input class="fi" id="fADept" placeholder="z.B. Statik"></div>
    </div>
    <div class="frow">
      <div class="fg"><label class="fl" id="lASoll">Soll-Stunden</label><input class="fi" type="number" id="fASoll" placeholder="0"></div>
      <div class="fg"><label class="fl" id="lAIst">Ist-Stunden</label><input class="fi" type="number" id="fAIst" placeholder="0"></div>
    </div>
    <div class="frow">
      <div class="fg"><label class="fl" id="lATermin">Fälligkeitsdatum</label><input class="fi" type="date" id="fATermin"></div>
      <div class="fg"><label class="fl" id="lAStatus">Status</label>
        <select class="fsel" id="fAStatus">
          <option value="Offen">Offen</option>
          <option value="In Bearbeitung">In Bearbeitung</option>
          <option value="In Prüfung">In Prüfung</option>
          <option value="Freigegeben">Freigegeben</option>
          <option value="Abgeschlossen">Abgeschlossen</option>
        </select>
      </div>
    </div>
    <div class="fg"><label class="fl" id="lAAbh">Abhängigkeit (benötigt)</label><input class="fi" id="fAAbh" placeholder="z.B. Druckberechnung abgeschlossen"></div>
    <div class="fg"><label class="fl" id="lANotes">Notizen</label><textarea class="fta" id="fANotes"></textarea></div>
    <div class="io-sec">
      <div class="io-sec-title" id="ioInTitle">📥 Eingangsdaten (Inputs)</div>
      <div id="inputList"></div>
      <button class="add-io" id="addInputBtn">+ Input hinzufügen</button>
    </div>
    <div class="io-sec">
      <div class="io-sec-title" id="ioOutTitle">📤 Ausgangsdaten (Outputs)</div>
      <div id="outputList"></div>
      <button class="add-io" id="addOutputBtn">+ Output hinzufügen</button>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" id="cancelAufg">Abbrechen</button>
      <button class="btn-save" id="saveAufg">Speichern</button>
    </div>
  </div>
</div>

<!-- MODAL: ADMIN LOGIN -->
<div class="overlay" id="modalAdmin">
  <div class="modal" style="max-width:340px">
    <div class="modal-title">🔐 Admin-Anmeldung</div>
    <div class="fg"><label class="fl">Passwort</label><input class="fi" type="password" id="fAdminPw" placeholder="••••••••"></div>
    <div id="adminErr" style="color:var(--coral);font-size:12px;margin-top:-6px;margin-bottom:8px;display:none">Falsches Passwort.</div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modalAdmin')">Abbrechen</button>
      <button class="btn-save" onclick="doAdminLogin()">Anmelden</button>
    </div>
  </div>
</div>

<!-- MODAL: REVISION -->
<div class="overlay" id="modalRev">
  <div class="modal" style="max-width:400px">
    <div class="modal-title" id="modalRevTitle">🔄 Revision erstellen</div>
    <div style="font-size:13px;color:var(--muted);margin-bottom:14px" id="revDesc">Die aktuelle Version wird archiviert. Neue Version startet mit "In Bearbeitung".</div>
    <div class="fg"><label class="fl" id="lRevGrund">Revisionsgrund</label><input class="fi" id="fRevGrund" placeholder="z.B. Kunde hat Geometrie geändert"></div>
    <div class="frow">
      <div class="fg"><label class="fl" id="lRevTermin">Neues Fälligkeitsdatum</label><input class="fi" type="date" id="fRevTermin"></div>
      <div class="fg"><label class="fl" id="lRevSoll">Neue Soll-Stunden</label><input class="fi" type="number" id="fRevSoll" placeholder="0"></div>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" id="cancelRev">Abbrechen</button>
      <button class="btn-save" id="saveRev" style="background:var(--amber)">Revision starten</button>
    </div>
  </div>
</div>

<script>
var lang = 'de';
var projects = [];
var activeProjId = null;
var editAufgId = null;
var revTargetId = null;
var activeFilter = 'all';
var currentUser = null; // null = eingeloggt als normaler Nutzer, 'admin' = Admin
var ADMIN_PW = 'Serhat1133.';
var viewRevAufgId = null; // hangi görevin revizyonu görüntüleniyor

var TR = {
  de: {
    projekte: 'Projekte', addProj: '+ Projekt hinzufügen', neuesProj: 'Neues Projekt',
    projName: 'Projektname', beschr: 'Beschreibung', verantw: 'Verantwortlich',
    endtermin: 'Endtermin', abbrechen: 'Abbrechen', speichern: 'Speichern',
    keineProj: 'Kein Projekt ausgewählt', addAufg: '+ Aufgabe hinzufügen',
    aufgName: 'Aufgabenname', abteilung: 'Abteilung', sollStd: 'Soll-Stunden',
    istStd: 'Ist-Stunden', faellig: 'Fälligkeitsdatum', status: 'Status',
    abh: 'Abhängigkeit (benötigt)', notizen: 'Notizen',
    inputs: '📥 Eingangsdaten (Inputs)', outputs: '📤 Ausgangsdaten (Outputs)',
    addInput: '+ Input hinzufügen', addOutput: '+ Output hinzufügen',
    neueAufg: 'Neue Aufgabe', bearbAufg: 'Aufgabe bearbeiten',
    alle: 'Alle', gesamt: 'Aufgaben gesamt', abgeschl: 'abgeschlossen',
    inBearb: 'In Bearbeitung', aktivAufg: 'aktive Aufgaben',
